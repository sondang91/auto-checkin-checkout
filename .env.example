# =============================================================================
# Upstash Redis (REQUIRED for production – data persistence)
# Tạo database miễn phí tại: https://console.upstash.com
# Sau đó copy REST URL và REST Token vào đây
# =============================================================================
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_rest_token_here

# Odoo Connection
ODOO_URL=https://arent.hr24.vn
ODOO_USERNAME=your@email.com
ODOO_PASSWORD=your_password
ODOO_DATABASE=arent-database

# Schedule (HH:mm, 24h)
CHECKIN_TIME=08:30
CHECKOUT_TIME=17:30
TIMEZONE=Asia/Ho_Chi_Minh
WORKING_DAYS=1,2,3,4,5

# Automation
AUTOMATION_ENABLED=true
MAX_RETRIES=3

# Email Notification (SMTP)
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=your@email.com
EMAIL_FROM=Auto Checkin <noreply@auto-checkin.com>

# API Security
CRON_SECRET=change-this-to-a-random-string

# =============================================================================
# Daily Report — Google Sheets Integration
# =============================================================================
# Sheet layout:  Column A = Date (YYYY-MM-DD or DD/MM/YYYY)
#                Column B = Report description
#                Column C = Status (auto-updated by app after sending)
#
# Setup steps:
#   1. Create a Google Cloud project at https://console.cloud.google.com
#   2. Enable Google Sheets API
#   3. Create a Service Account → download JSON key
#   4. Share the Google Sheet with the service account email (Editor access)
#   5. Copy values from the JSON key file into the env vars below
# =============================================================================
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SHEET_NAME=Daily Report

# From the Service Account JSON key file:
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the private_key value exactly (with \n for newlines):
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"

# =============================================================================
# Odoo Daily Report Task Config
# =============================================================================
REPORT_PROJECT_ID=230          # project.project ID on Odoo
REPORT_PLANNED_HOURS=8         # planned_hours for the task
REPORT_COMPANY_ID=1            # company_id context
REPORT_TAG_ID=5                # tag id to assign (0 = no tag)
REPORT_TASK_NAME=Daily report  # task name prefix (date appended automatically)
